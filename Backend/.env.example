PORT=3001
NODE_ENV=production
CLIENT_URL=https://your-frontend-domain.example
JWT_SECRET=replace-with-a-long-random-secret

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/explore_lesotho
MONGODB_DB_NAME=explore_lesotho

# MySQL
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-mysql-user
DB_PASSWORD=your-mysql-password
DB_NAME=explore_lesotho

# Optional ML proxy target if hosted separately
ML_SERVICE_URL=https://your-ml-service.example/api/ml
