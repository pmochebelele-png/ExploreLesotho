PORT=3001
NODE_ENV=production
CLIENT_URL=https://your-frontend-domain.example
JWT_SECRET=replace-with-a-long-random-secret

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/explore_lesotho
MONGODB_DB_NAME=explore_lesotho

# MySQL
# Railway can provide a single MySQL URL. Use one of these if available:
# MYSQL_URL=mysql://user:password@host:port/database
# MYSQL_PUBLIC_URL=mysql://user:password@host:port/database
# DATABASE_URL=mysql://user:password@host:port/database
#
# Or use Railway's separate MySQL variables:
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-mysql-user
DB_PASSWORD=your-mysql-password
DB_NAME=explore_lesotho

# Optional ML proxy target if hosted separately
ML_SERVICE_URL=https://your-ml-service.example/api/ml

# Optional real email delivery for verification and password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Explore Lesotho <your-email@gmail.com>"
