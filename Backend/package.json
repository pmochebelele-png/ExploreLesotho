{
  "name": "explore-lesotho-backend",
  "version": "2.0.0",
  "description": "Explore Lesotho - Digital Tourism Platform Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "import:db": "node scripts/import-sql-file.js ../_db_exports/explore_lesotho_local.sql",
    "user:upsert": "node scripts/upsert-user.js",
    "import:culture": "node scripts/import-culture-directory.js",
    "backfill:culture": "node scripts/backfill-culture-from-listings.js",
    "test": "mocha tests/**/*.js --timeout 10000",
    "test:watch": "mocha tests/**/*.js --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "3.7",
    "mysql2": "^3.9.0",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "chai": "^4.3.10",
    "eslint": "^8.56.0",
    "mocha": "^7.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0 <23.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "lesotho",
    "tourism",
    "digital-platform",
    "mongodb",
    "mysql",
    "express"
  ],
  "author": "Explore Lesotho Team",
  "license": "ISC"
}
